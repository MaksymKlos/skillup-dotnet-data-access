root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# C# / project files
[*.{cs,csx}]
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Prefer file-scoped namespaces, var when apparent, expression-bodied members
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_prefer_braces = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

# Naming: private fields _camelCase, interfaces IPascalCase (defaults are fine; kept minimal)

[*.{csproj,props,targets}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# EF Core migrations are generated code — follow EF's formatting, not our style rules.
[**/Migrations/**.cs]
generated_code = true
